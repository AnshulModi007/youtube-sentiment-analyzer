{
  "manifest_version": 3,
  "name": "YouTube Sentiment Analyzer",
  "version": "1.0.0",
  "description": "Analyze the sentiment of YouTube video comments using ML",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://www.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "icons": {
    "128": "icon128.png"
  }
}